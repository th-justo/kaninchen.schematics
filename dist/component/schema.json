{
  "$schema": "http://json-schema.org/schema",
  "$id": "ComponentSchema",
  "title": "Kaninchen Component Options",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Component name"
    },
    "path": {
      "type": "string",
      "default": "src/app/components"
    },
    "style": {
      "type": "string",
      "description": "The style type (css, scss, sass, less, etc.)",
      "default": "scss"
    }
  },
  "required": [
    "name"
  ]
}